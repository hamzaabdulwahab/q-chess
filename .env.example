# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional: explicit auth cookie domain. Set ONLY if your deployment spans
# multiple hosts that must share the session (e.g. apex + www, or subdomains):
#   AUTH_COOKIE_DOMAIN=.example.com
# Leave unset for single-host deployments.
# AUTH_COOKIE_DOMAIN=

# Keep-alive Security (used by /api/cron/keep-alive)
# Use with an external scheduler (e.g. UptimeRobot, cron-job.org, GitHub Actions).
CRON_SECRET=replace_with_a_long_random_secret

# ───── Stockfish bot ─────────────────────────────────────────────────
# All of these are optional. Defaults are tuned for Vercel Fluid Compute
# running the bundled WASM build of Stockfish 18.
#
# STOCKFISH_PATH
#   Absolute path to a native Stockfish binary. Set this on a VPS or
#   Docker deployment for maximum strength. If unset, the app falls
#   back to the WASM build shipped in node_modules/stockfish.
#     mac:   /opt/homebrew/bin/stockfish
#     linux: /usr/games/stockfish or /usr/local/bin/stockfish
# STOCKFISH_PATH=
#
# STOCKFISH_THREADS (default 2, max 8)
#   Search threads for the engine.
# STOCKFISH_THREADS=2
#
# STOCKFISH_HASH_MB (default 128, max 2048)
#   Transposition-table size in MB.
# STOCKFISH_HASH_MB=128
#
# STOCKFISH_MASTER_MOVETIME_MS (default 1500)
#   Movetime for the Master difficulty. ~1.5s gives a genuinely strong
#   search. Forced and book-opening moves are answered instantly regardless.
# STOCKFISH_MASTER_MOVETIME_MS=1500
#
# STOCKFISH_MONSTER_MOVETIME_MS (default 2500)
#   Movetime for the Monster (max) difficulty. ~2.5s for the hardest
#   opponent. Bump for even longer thinks (the route's maxDuration is 30s).
# STOCKFISH_MONSTER_MOVETIME_MS=2500
#
# STOCKFISH_REQUEST_TIMEOUT_MS (default 4000)
#   Slack added on top of movetime to form the hard search backstop, so the
#   backstop always exceeds the chosen movetime (movetime + this value).
# STOCKFISH_REQUEST_TIMEOUT_MS=4000
#
# STOCKFISH_RATE_LIMIT_PER_MINUTE (default 60)
#   Per-user requests/minute cap. Stops abuse of the engine endpoint.
# STOCKFISH_RATE_LIMIT_PER_MINUTE=60
